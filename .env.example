BOT_TOKEN=your-telegram-bot-token
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/mydb?retryWrites=true&w=majority
EMAIL=your-lancers@email.com
PASSWORD=your-lancers-password
ADMIN_ID=your-telegram-numeric-id
# Chromium persistent profile (cookies survive bot restarts). Default: <repo>/data/lancers-chromium-profile
# LANCERS_BROWSER_USER_DATA_DIR=C:/path/to/lancers-chromium-profile
# LANCERS_HEADLESS=true
# Speed experiment: block CSS/fonts/images/media + common tracker scripts (can break layout; off by default).
# LANCERS_BLOCK_STATIC_ASSETS=true
# Optional; legacy
OPENAI_API=
# Bid body: "template" = data/template.txt (default). "api" = BID_API_URL.
BID_TEXT_SOURCE=template
# Used when BID_TEXT_SOURCE=api
BID_API_URL=http://135.181.224.37:3000/api/project-links
BID_API_KEY=
# Matches API "count" field (string).
BID_API_COUNT=5
# Long timeout for LLM-style generation (ms).
BID_API_TIMEOUT_MS=120000
# Playwright: random delay between form steps (anti-bot; tune slower if needed).
BID_BROWSER_DELAY_MIN_MS=1000
BID_BROWSER_DELAY_MAX_MS=3000
# Fallback 完了予定日 (days from today) when no 希望納期 on detail page and listing budget is unparseable.
BID_COMPLETION_DAYS=14
# Max autobids per rolling window
BID_MAX_PER_WINDOW=5
# Rolling window (ms), default 1 hour
BID_RATE_WINDOW_MS=3600000
# Scrape loop: pause between search iterations
SCRAPE_DELAY_MIN_MS=4000
SCRAPE_DELAY_MAX_MS=8000
# PROXY=http://host:port
# PROXY_AUTH={"username":"...","password":"..."}

LANCERS_ACCOUNT_ID=your_account
LANCERS_ACCOUNT_URL=https://www.lancers.jp/profile/your_account
# After a successful bid: POST rank before BID_RECORD. Response key must match LANCERS_ACCOUNT_ID. Set empty to skip.
BID_RANKS_API_URL=http://213.210.13.163:3003/api/lancers/bid-ranks
# any = notify all new jobs + auto-bid all (no min/max filter). set = notify + bid only if budget in [min,max].
JOB_NOTIFY_PRICE=any
# Used only when JOB_NOTIFY_PRICE=set — listing の予算（パースした上限）がこの範囲内のみ。
BID_MIN_BUDGET_JPY=50000
BID_MAX_BUDGET_JPY=200000
